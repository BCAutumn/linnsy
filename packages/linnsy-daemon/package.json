{
  "name": "linnsy-daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "linnsy": "./dist/cli.cjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src",
    "test:contract": "vitest run __tests__/contract",
    "test:e2e": "vitest run __tests__/e2e",
    "test:renderer": "vitest run app/renderer",
    "test:platform": "vitest run __tests__/platform",
    "test:chaos": "vitest run __tests__/chaos --fileParallelism=false",
    "guard:boundary": "tsx scripts/guard-boundary.ts",
    "dev:doctor": "tsx src/cli/doctor.ts",
    "dev:daemon": "tsx src/cli/index.ts chat:audit",
    "dev:frontend": "vite --config app/renderer/vite.config.ts",
    "dev:electron": "tsx electron/dev.ts",
    "dev:wechat-gateway": "tsx src/cli/index.ts wechat-gateway",
    "build:frontend": "vite build --config app/renderer/vite.config.ts",
    "build:electron": "tsx electron/build-electron.ts",
    "build": "tsup",
    "rebuild:better:node": "npm rebuild better-sqlite3",
    "rebuild:better:electron": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "@linnlabs/linnkit": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/markdown": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "grammy": "^1.42.0",
    "hono": "^4.6.0",
    "nanoid": "^5.1.0",
    "openai": "^5.19.1",
    "pino": "^8.21.0",
    "pino-pretty": "^11.3.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "stream-markdown-parser": "^0.0.45",
    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "electron": "^33.0.0",
    "eslint": "^9.15.0",
    "happy-dom": "^17.6.3",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.16.0",
    "vite": "6.4.2",
    "vitest": "3.2.4"
  },
  "overrides": {
    "glob": "13.0.6",
    "vite": "6.4.2"
  }
}
